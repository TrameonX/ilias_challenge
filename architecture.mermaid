flowchart TB
    subgraph UI["UI Layer — Gradio"]
        G["Gradio app<br/>upload widget + status<br/>polling toutes les 2s"]
    end

    subgraph API["API Layer — FastAPI"]
        U["POST /upload<br/>valide + renvoie job_id (202)"]
        R["GET /result/{job_id}<br/>status + insights"]
    end

    subgraph SVC["Service Layer"]
        JS["JobService<br/>orchestration du pipeline<br/>gestion des erreurs"]
    end

    subgraph PROC["Processing Layer"]
        V["Validation<br/>type + taille"]
        P["Preprocessing<br/>TXT / PDF -> texte"]
        subgraph INF["Inference (swappable)"]
            BASE["ModelClient (interface)"]
            ANTH["AnthropicClient"]
            OAI["OpenAIClient"]
            MOCK["MockClient"]
            FAC["factory.get_model_client()"]
        end
    end

    subgraph STORE["Storage Layer"]
        DB["InMemoryJobStore<br/>(swappable: Redis/SQL)"]
    end

    G -- "HTTP" --> U
    G -- "HTTP poll" --> R
    U --> JS
    R --> DB
    JS --> V --> P --> FAC
    FAC --> BASE
    BASE -.-> ANTH
    BASE -.-> OAI
    BASE -.-> MOCK
    FAC --> JS
    JS --> DB

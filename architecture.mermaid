flowchart TB
    subgraph UI["UI Layer — Gradio (Julie)"]
        G["UI_July/app.py<br/>upload + choix tâche<br/>polling /result toutes les 2s"]
    end

    subgraph API["API Layer — FastAPI (Mathieu)"]
        U["POST /upload<br/>file + task → renvoie job_id"]
        R["GET /result/{job_id}<br/>status + result"]
    end

    subgraph SVC["Service Layer (Mathieu)"]
        JS["FileProcessingService<br/>orchestration + gestion d'erreur<br/>(corrompu/échec → FAILED)"]
    end

    subgraph PROC["Processing Layer"]
        V["Validation<br/>type TXT/PDF + taille ≤ 5 MB"]
        P["Preprocessing<br/>extraction texte PDF / TXT"]
        subgraph INF["Inference — swappable"]
            ADP["ai_adapter.RealAIModel<br/>(implémente AbstractAIModel)"]
            FAC["factory.get_model_client()<br/>via MODEL_PROVIDER"]
            BASE["ModelClient (interface)"]
            ANTH["AnthropicClient"]
            OAI["OpenAIClient"]
            MOCK["MockClient"]
        end
    end

    subgraph STORE["Storage Layer (Mathieu)"]
        DB["JobRepository<br/>in-memory (swappable: Redis/SQL)"]
    end

    G -- "HTTP POST" --> U
    G -- "HTTP poll 2s" --> R
    U --> JS
    R --> DB
    JS --> V --> P --> ADP
    ADP --> FAC --> BASE
    BASE -.-> ANTH
    BASE -.-> OAI
    BASE -.-> MOCK
    ADP --> JS
    JS --> DB

    classDef steph fill:#e8f0ff,stroke:#3b6fd6,stroke-width:1px;
    class ADP,FAC,BASE,ANTH,OAI,MOCK steph;

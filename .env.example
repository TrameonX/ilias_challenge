# Copier en .env et adapter.

# --- Modèle (swappable) ---
# anthropic | openai | mock
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-3-5-haiku-latest

# Tâche IA : sentiment | summarize | keywords | qa
AI_TASK=sentiment

# --- Clés API ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Validation ---
MAX_FILE_SIZE_MB=5

# --- UI ---
# Local (dev isolé) : http://localhost:8000
# Mode équipe : URL du tunnel de l'hébergeur, ex. https://xxxx.ngrok.io
API_URL=http://localhost:8000
